{
  "packages": {
    "Packages/src": {
      "release-type": "node",
      "versioning": "prerelease",
      "prerelease": true,
      "prerelease-type": "beta",
      "include-v-in-tag": true,
      "include-component-in-tag": false,
      "extra-files": [
        {
          "type": "json",
          "path": "Cli~/Core~/internal/presentation/cli/default-tools.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "Cli~/Core~/contract.json",
          "jsonpath": "$.coreVersion"
        },
        {
          "type": "json",
          "path": "Cli~/Core~/contract.json",
          "jsonpath": "$.minimumRequiredDispatcherVersion"
        },
        {
          "type": "json",
          "path": "Cli~/Dispatcher~/contract.json",
          "jsonpath": "$.dispatcherVersion"
        },
        {
          "type": "generic",
          "path": "Packages/src/Editor/Config/McpVersion.cs",
          "glob": "Packages/src/Editor/Config/McpVersion.cs"
        }
      ]
    }
  }
}

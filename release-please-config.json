{
  "packages": {
    "Packages/src": {
      "release-type": "node",
      "versioning": "prerelease",
      "prerelease": true,
      "prerelease-type": "beta",
      "include-v-in-tag": true,
      "include-component-in-tag": false,
      "extra-files": [
        {
          "type": "json",
          "path": "Cli~/Core~/internal/presentation/cli/default-tools.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "Packages/src/Cli~/Core~/internal/presentation/cli/tools.go",
          "glob": "Packages/src/Cli~/Core~/internal/presentation/cli/tools.go"
        },
        {
          "type": "generic",
          "path": "Packages/src/Editor/Config/McpVersion.cs",
          "glob": "Packages/src/Editor/Config/McpVersion.cs"
        }
      ]
    }
  }
}

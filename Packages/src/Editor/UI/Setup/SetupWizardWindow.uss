/* ===========================================
   SetupWizardWindow Stylesheet
   =========================================== */

:root {
    --setup-color-success: #4caf50;
    --setup-color-warning: #ffd200;
    --setup-color-danger: #ef5350;
    --setup-color-muted: #999999;
}

/* ===========================================
   Block: Main Container
   =========================================== */
.setup-main-container {
    padding: 12px;
}

/* ===========================================
   Block: Prerequisite
   =========================================== */
.setup-prerequisite {
    border-width: 1px;
    border-radius: 3px;
    padding: 8px 12px;
    margin-bottom: 12px;
}

.setup-prerequisite--warning {
    background-color: #5c4a00;
    border-color: #7a6400;
}

.setup-prerequisite--ok {
    background-color: #1b3a1b;
    border-color: #2e7d32;
}

.setup-prerequisite--compact {
    justify-content: center;
    min-height: 36px;
}

.setup-prerequisite__title {
    -unity-font-style: bold;
    margin-bottom: 4px;
}

.setup-prerequisite--compact .setup-prerequisite__title {
    margin-bottom: 0;
}

.setup-prerequisite--warning .setup-prerequisite__title {
    color: var(--setup-color-warning);
}

.setup-prerequisite--ok .setup-prerequisite__title {
    color: var(--setup-color-success);
}

.setup-prerequisite__message {
    white-space: normal;
    margin-bottom: 6px;
}

/* ===========================================
   Block: Step
   =========================================== */
.setup-step {
    background-color: var(--unity-colors-helpbox-background);
    border-color: var(--unity-colors-helpbox-border);
    border-width: 1px;
    border-radius: 3px;
    padding: 8px 12px;
    margin-bottom: 8px;
}

.setup-step__title {
    -unity-font-style: bold;
    font-size: 13px;
    margin-bottom: 6px;
}

.setup-step__content {
    padding-left: 4px;
}

.setup-step__status-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 6px;
}

.setup-step__status-label {
    margin-left: 6px;
}

/* ===========================================
   Block: Status Icon
   =========================================== */
.setup-status-icon {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    flex-shrink: 0;
}

.setup-status-icon--pending {
    background-color: var(--setup-color-muted);
}

.setup-status-icon--success {
    background-color: var(--setup-color-success);
}

/* ===========================================
   Block: Target
   =========================================== */
.setup-target-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 6px;
    overflow: hidden;
}

.setup-target-row__label {
    width: 50px;
    flex-shrink: 0;
    margin-right: 6px;
}

.setup-target-row__field {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
}

.setup-target-list {
    margin-bottom: 6px;
}

.setup-toggle-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 6px;
}

.setup-toggle-row__toggle {
    width: 20px;
    margin-right: 4px;
}

.setup-toggle-row__label {
    flex-grow: 1;
    white-space: normal;
}

.setup-target-item {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
    margin-left: 4px;
}

.setup-target-item__label {
    flex-grow: 1;
    margin-right: 8px;
}

.setup-target-item__status {
    flex-shrink: 0;
    -unity-font-style: bold;
}

.setup-target-item__status--installed {
    color: var(--setup-color-success);
}

.setup-target-item__status--checking {
    color: var(--setup-color-muted);
}

.setup-target-item__status--outdated {
    color: var(--setup-color-warning);
}

.setup-target-item__status--missing {
    color: var(--setup-color-muted);
}

.setup-target-item__status--different-layout {
    color: var(--setup-color-warning);
}

/* ===========================================
   Block: Button
   =========================================== */
.setup-button {
    margin-top: 4px;
    margin-bottom: 4px;
}

.setup-button--small {
    height: 22px;
    padding-left: 12px;
    padding-right: 12px;
    font-size: 11px;
    align-self: flex-start;
}

.setup-button--primary {
    background-color: #2e7d32;
    border-color: var(--setup-colo--setup-color-dividerr-success);
    color: #ffffff;
}

.setup-button--primary:hover {
    background-color: #388e3c;
}

/* ===========================================
   Element: Hint Label
   =========================================== */
.setup-step__hint-label {
    font-size: 11px;
    color: var(--setup-color-muted);
    white-space: normal;
    margin-top: 4px;
}

.setup-step__divider {
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.12);
    margin-top: 6px;
    margin-bottom: 12px;
}

/* ===========================================
   Block: Footer
   =========================================== */
.setup-footer__toggle {
    margin-top: 6px;
}

.setup-footer__hint-label {
    font-size: 11px;
    color: var(--setup-color-muted);
    white-space: normal;
    margin-top: 2px;
    margin-left: 18px;
}

.setup-footer__button-row {
    flex-direction: row;
}

.setup-footer__button-row .setup-button {
    flex-grow: 1;
    flex-basis: 0;
}

.setup-footer__github-link {
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.12);
    padding-top: 8px;
    margin-top: 10px;
    opacity: 0.78;
}

.setup-footer__github-link-label {
    font-size: 11px;
    color: #c3cad3;
    margin-right: 5px;
}

.setup-footer__github-link-icon {
    width: 16px;
    height: 16px;
    opacity: 0.78;
    -unity-background-scale-mode: scale-to-fit;
}

.setup-footer__github-link--hover {
    opacity: 1;
}

.setup-footer__github-link-label--hover {
    color: #ffffff;
}

.setup-footer__github-link-icon--hover {
    opacity: 1;
}

.setup-step__button-row {
    flex-direction: row;
    margin-top: 4px;
}

.setup-step__button-row .setup-button {
    flex-grow: 1;
    flex-basis: 0;
}

/* ===========================================
   Utility: Hidden
   =========================================== */
.setup-hidden {
    display: none;
}

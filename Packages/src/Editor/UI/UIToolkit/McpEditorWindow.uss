/* ===========================================
   McpEditorWindow UI Toolkit Stylesheet
   Using BEM naming convention and Unity theme variables
   =========================================== */

:root {
    --mcp-color-success: #4caf50;
    --mcp-color-danger: #ef5350;
    --mcp-color-warning: #ffd200;
}

/* Main Container */
.mcp-window-root {
    flex-direction: column;
    flex-grow: 1;
    flex-shrink: 1;
    min-height: 0;
}

.mcp-main-container {
    flex-grow: 1;
    flex-shrink: 1;
    min-height: 0;
    padding: 4px;
}

.mcp-main-container--debug {
    background-color: rgba(128, 0, 128, 0.15);
}

/* ===========================================
   Block: Section
   =========================================== */
.mcp-section {
    margin-bottom: 8px;
}

.mcp-section--box {
    background-color: var(--unity-colors-helpbox-background);
    border-color: var(--unity-colors-helpbox-border);
    border-width: 1px;
    border-radius: 3px;
    padding: 8px;
    overflow: hidden;
}

/* ===========================================
   Block: Server Status (prominent status row)
   =========================================== */
.mcp-server-status {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
    margin-left: 7px;
}

.mcp-server-status__indicator {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    margin-right: 6px;
    flex-shrink: 0;
}

.mcp-server-status__indicator--running {
    background-color: var(--mcp-color-success);
}

.mcp-server-status__indicator--stopped {
    background-color: var(--mcp-color-danger);
}

.mcp-server-status__text {
    -unity-font-style: bold;
}

.mcp-server-status__text--running {
    color: var(--mcp-color-success);
    border-color: var(--mcp-color-success);
    border-width: 1px;
    border-radius: 3px;
    padding: 2px 6px;
}

.mcp-server-status__text--stopped {
    color: var(--mcp-color-danger);
    border-color: var(--mcp-color-danger);
    border-width: 1px;
    border-radius: 3px;
    padding: 2px 6px;
}

.mcp-server-status__spacer {
    flex-grow: 1;
}

/* ===========================================
   Block: Server Controls (compact row)
   =========================================== */
.mcp-server-controls {
    margin-top: 4px;
    padding-left: 8px;
}

.mcp-server-controls .mcp-button {
    flex-grow: 1;
}

/* ===========================================
   Block: Warning Container
   =========================================== */
.mcp-warning-container {
    display: none;
    margin-bottom: 8px;
}

.mcp-warning-container--visible {
    display: flex;
}

.mcp-warning-label {
    background-color: #5c4a00;
    border-color: #7a6400;
    color: #ffcc00;
    border-width: 1px;
    border-radius: 3px;
    padding: 8px;
    white-space: normal;
}

/* ===========================================
   Block: Button
   =========================================== */
.mcp-button {
    margin-top: 4px;
    margin-bottom: 4px;
}

.mcp-button--compact {
    height: 22px;
    padding-left: 12px;
    padding-right: 12px;
    font-size: 11px;
    margin-top: 4px;
    margin-bottom: 4px;
    margin-left: 0;
}

.mcp-button--start {
    background-color: #2e7d32;
    border-color: var(--mcp-color-success);
    color: #ffffff;
}

.mcp-button--start:hover {
    background-color: #388e3c;
}

.mcp-button--stop {
    background-color: #4a4a4a;
    border-color: #666666;
    color: #ff6b6b;
}

.mcp-button--stop:hover {
    background-color: #555555;
}

.mcp-button--warning {
    background-color: #665522;
    border-color: #aa9944;
}

.mcp-button--warning:hover {
    background-color: #887744;
}

.mcp-button--configure {
    margin-top: 8px;
}

#install-cli-button {
    margin-top: 2px;
}

.mcp-button--delete {
    margin-top: 12px;
    color: #ff6b6b;
}

.mcp-button--delete:hover {
    color: #ff8a8a;
}

.mcp-button--disabled {
    background-color: #4a4a4a;
    border-width: 1px;
    border-color: rgba(128, 128, 128, 0.5);
    color: #999999;
    opacity: 1;
}

/* ===========================================
   Block: Toggle Row
   =========================================== */
.mcp-toggle-row {
    flex-direction: row;
    align-items: center;
    margin-top: 4px;
    margin-bottom: 4px;
}

.mcp-toggle-row__toggle {
    width: 20px;
    margin-right: 4px;
}

.mcp-toggle-row__label {
    flex-grow: 1;
}

.mcp-toggle-row__label--danger {
    color: var(--mcp-color-warning);
}

/* ===========================================
   Block: Target Row (Editor Selection)
   =========================================== */
.mcp-target-row {
    flex-direction: row;
    align-items: center;
    overflow: hidden;
}

.mcp-target-row__label {
    width: 50px;
    flex-shrink: 0;
}

.mcp-target-row__field {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    overflow: hidden;
}

/* ===========================================
   Block: Foldout
   =========================================== */
.mcp-foldout {
    margin-left: -8px;
}

#tool-settings-foldout > .unity-foldout__content {
    margin-top: 2px;
    padding-top: 0;
}

/* ===========================================
   Block: Client (Connected Tools Item)
   =========================================== */
.mcp-clients-list {
    margin-top: 4px;
}

.mcp-client {
    background-color: rgba(76, 76, 76, 0.5);
    border-width: 1px;
    border-color: rgba(128, 128, 128, 0.5);
    border-radius: 3px;
    padding: 8px;
    margin-left: 3px;
    margin-right: 3px;
    margin-bottom: 6px;
    flex-direction: row;
    align-items: center;
}

.mcp-client__icon {
    color: var(--mcp-color-success);
    margin-right: 4px;
}

.mcp-client__name {
    -unity-font-style: bold;
    flex-grow: 1;
}

/* ===========================================
   Block: Messages
   =========================================== */
.mcp-info-message {
    display: none;
    background-color: var(--unity-colors-helpbox-background);
    border-color: var(--unity-colors-helpbox-border);
    border-width: 1px;
    border-radius: 3px;
    padding: 8px;
    margin-top: 8px;
    white-space: normal;
}

.mcp-info-message--visible {
    display: flex;
}

.mcp-warning-message {
    display: none;
    background-color: #5c4a00;
    border-color: #7a6400;
    color: #ffcc00;
    border-width: 1px;
    border-radius: 3px;
    padding: 8px;
    margin-top: 8px;
    white-space: normal;
}

.mcp-warning-message--visible {
    display: flex;
}

.mcp-error-message {
    display: none;
    background-color: var(--unity-colors-error-background, #440000);
    border-color: var(--unity-colors-error-border, #aa0000);
    border-width: 1px;
    border-radius: 3px;
    padding: 8px;
    margin-top: 8px;
    margin-bottom: 8px;
    white-space: normal;
    color: var(--unity-colors-error-text, #ff4444);
}

.mcp-error-message--visible {
    display: flex;
}

/* ===========================================
   Block: Tool Settings
   =========================================== */
.mcp-tool-settings-info {
    white-space: normal;
    margin-top: 14px;
    margin-bottom: 4px;
}

.mcp-tool-settings-note {
    font-size: 10px;
    color: #888888;
    white-space: normal;
    margin-bottom: 8px;
}

.mcp-tool-settings-link {
    font-size: 10px;
    color: #4C7EF3;
    white-space: normal;
    margin-bottom: 8px;
    cursor: link;
    -unity-font-style: italic;
}

.mcp-tool-settings-link:hover {
    color: #6B9AFF;
}

.mcp-tool-settings-content {
    margin-top: 0;
    padding-top: 0;
}

#tool-settings-info-container {
    padding-left: 14px;
}

.mcp-tool-settings-card {
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.22);
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.03);
    padding: 0px 8px 8px 8px;
    margin-bottom: 12px;
}

.mcp-tool-settings-card__header {
    margin-top: 0;
    padding-top: 0;
    margin-bottom: 2px;
}

.mcp-tool-group-header {
    -unity-font-style: bold;
    margin-top: 6px;
    margin-bottom: 4px;
}

.mcp-tool-group--disabled {
    opacity: 0.45;
}

.mcp-permission-item {
    margin-top: 8px;
    padding: 8px 0 0 14px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.08);
}

.mcp-permission-item--first {
    margin-top: 0;
    padding-top: 4px;
    border-top-width: 0;
}

.mcp-permission-item__title {
    margin-top: 0;
    margin-bottom: 6px;
    color: var(--mcp-color-warning);
}

.mcp-permission-item__title--dynamic-code {
    font-size: 13px;
}

.mcp-permission-item__control-row {
    flex-direction: row;
    align-items: center;
}

.mcp-permission-item__control-label {
    min-width: 0;
    margin-right: 0;
    color: rgba(255, 255, 255, 0.75);
}

.mcp-permission-item__toggle-row {
    margin-top: 0;
    margin-bottom: 0;
}

.mcp-permission-item__assistive-label {
    display: none;
}

.mcp-segmented-control {
    flex-direction: row;
    margin-top: 4px;
    margin-bottom: 4px;
    background-color: rgba(48, 48, 48, 0.6);
    border-radius: 3px;
    border-width: 1px;
    border-color: rgba(128, 128, 128, 0.2);
}

.mcp-segmented-control__button {
    flex-grow: 1;
    height: 20px;
    margin: 0;
    border-radius: 2px;
    border-width: 1px;
    border-color: transparent;
    background-color: transparent;
    color: rgba(255, 255, 255, 0.5);
    -unity-font-style: normal;
    font-size: 11px;
}

.mcp-segmented-control__button:hover {
    background-color: rgba(46, 90, 136, 0.3);
    color: rgba(255, 255, 255, 0.7);
    border-width: 1px;
    border-color: rgba(70, 130, 200, 0.4);
}

#security-level-full-access-button:hover {
    background-color: rgba(122, 39, 39, 0.35);
    color: #ffe3e3;
    border-width: 1px;
    border-color: rgba(178, 76, 76, 0.55);
}

.mcp-segmented-control__button--active {
    background-color: rgba(46, 90, 136, 0.8);
    color: #ffffff;
    border-width: 1px;
    border-color: rgba(70, 130, 200, 0.4);
}

.mcp-segmented-control__button--warning-active {
    background-color: rgba(122, 39, 39, 0.85);
    color: #ffd7d7;
    border-width: 1px;
    border-color: rgba(178, 76, 76, 0.7);
}

.mcp-tool-toggle-row {
    flex-direction: row;
    align-items: center;
    padding: 2px 4px 2px 14px;
    margin-top: 1px;
    margin-bottom: 1px;
}

.mcp-tool-toggle-row__toggle {
    margin-right: 4px;
}

.mcp-tool-toggle-row__label {
    flex-grow: 1;
}

.mcp-tool-list-container {
    padding-left: 0;
}

.mcp-tool-list-view {
    margin-top: 4px;
    margin-left: 0;
    margin-right: 0;
    border-width: 0;
    background-color: transparent;
}

.mcp-tool-list-row {
    min-height: 24px;
}

.mcp-tool-list-row--header {
    padding-top: 0;
    padding-bottom: 0;
}

.mcp-tool-list-row--disabled {
    opacity: 0.45;
}

.mcp-tool-registry-unavailable {
    color: #888888;
    -unity-font-style: italic;
    margin-top: 4px;
}

/* ===========================================
   Block: Security
   =========================================== */
.mcp-security-warning {
    background-color: #5c4a00;
    border-color: #7a6400;
    border-width: 1px;
    border-radius: 3px;
    padding: 8px;
    margin-bottom: 8px;
    white-space: normal;
    color: #ffcc00;
}

.mcp-section-header {
    -unity-font-style: bold;
    margin-top: 10px;
    margin-bottom: 4px;
}

.mcp-section-header--danger {
    color: var(--mcp-color-warning);
}

.mcp-security-level-field {
    margin-top: 4px;
    margin-bottom: 4px;
}

.mcp-security-level-description {
    background-color: var(--unity-colors-helpbox-background);
    border-color: var(--unity-colors-helpbox-border);
    border-width: 1px;
    border-radius: 3px;
    padding: 8px;
    margin-top: 6px;
    white-space: normal;
}

.mcp-security-level-description--warning {
    background-color: #5c4a00;
    border-color: #7a6400;
    color: #ffcc00;
}

/* ===========================================
   Block: CLI Setup
   =========================================== */
.mcp-cli-subsection-header {
    -unity-font-style: bold;
    margin-top: 6px;
    margin-bottom: 4px;
}

.mcp-cli-separator {
    height: 1px;
    margin-top: 10px;
    margin-bottom: 6px;
    background-color: rgba(255, 255, 255, 0.12);
}

.mcp-cli-status-row {
    flex-direction: row;
    align-items: center;
    margin-top: 4px;
    margin-bottom: 4px;
}

#cli-status-label {
    flex-grow: 1;
}

.mcp-cli-status-icon {
    width: 8px;
    height: 8px;
    border-radius: 4px;
    margin-right: 6px;
}

.mcp-cli-status-icon--installed {
    background-color: var(--mcp-color-success);
}

.mcp-cli-status-icon--not-installed {
    background-color: rgba(128, 128, 128, 0.5);
}

.mcp-button--refresh {
    width: 20px;
    height: 20px;
    min-width: 20px;
    margin: 0 3px 0 4px;
    padding: 0;
    font-size: 14px;
    -unity-text-align: middle-center;
    border-radius: 2px;
}

/* ===========================================
   Block: GitHub Link
   =========================================== */
.mcp-github-link {
    flex-direction: row;
    justify-content: flex-end;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
    padding-right: 10px;
    padding-bottom: 4px;
    padding-left: 4px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.08);
    margin-right: 6px;
    opacity: 0.78;
}

.mcp-github-link__label {
    font-size: 11px;
    color: #c3cad3;
    margin-right: 5px;
}

.mcp-github-link__icon {
    width: 16px;
    height: 16px;
    opacity: 0.78;
    -unity-background-scale-mode: scale-to-fit;
}

.mcp-github-link--hover {
    opacity: 1;
}

.mcp-github-link__label--hover {
    color: #ffffff;
}

.mcp-github-link__icon--hover {
    opacity: 1;
}

/* ===========================================
   Utility: Hidden
   =========================================== */
.mcp-hidden {
    display: none;
}

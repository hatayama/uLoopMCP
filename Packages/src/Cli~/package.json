{
  "name": "uloop-cli",
  "version": "3.0.0",
  "//version": "x-release-please-version",
  "description": "CLI tool for Unity Editor communication via Unity CLI Loop",
  "main": "dist/dispatcher.bundle.cjs",
  "bin": {
    "uloop": "dist/dispatcher.bundle.cjs"
  },
  "type": "module",
  "scripts": {
    "build": "esbuild src/dispatcher.ts --bundle --platform=node --format=cjs --outfile=dist/dispatcher.bundle.cjs --sourcemap --banner:js=\"#!/usr/bin/env node\" && esbuild src/cli.ts --bundle --platform=node --format=cjs --outfile=dist/cli.bundle.cjs --sourcemap --banner:js=\"#!/usr/bin/env node\" --loader:.md=text",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "knip": "knip",
    "test:cli": "jest src/__tests__ --testTimeout=60000 --runInBand"
  },
  "keywords": [
    "cli",
    "unity",
    "uloop"
  ],
  "author": "hatayama",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hatayama/unity-cli-loop.git",
    "directory": "Packages/src/Cli~"
  },
  "bugs": {
    "url": "https://github.com/hatayama/unity-cli-loop/issues"
  },
  "homepage": "https://github.com/hatayama/unity-cli-loop#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "commander": "14.0.3",
    "launch-unity": "^0.17.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-security": "4.0.0",
    "jest": "30.3.0",
    "knip": "6.8.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1"
  },
  "overrides": {
    "minimatch": "10.2.4"
  }
}
